<!doctype html>
<html lang="en-US">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>MRD LoD design tool — {{ name }}</title>
<!--
  Self-contained MRD limit-of-detection design tool (BUILD_SPEC 8).
  Plotly is loaded from CDN. To run fully offline, download plotly.min.js and
  replace the <script src="https://cdn.plot.ly/..."> tag below with an inline
  <script>…</script> containing its contents.
-->
<script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
<style>
  :root{
    --bg:#f7f8fa; --panel:#ffffff; --ink:#1a2230; --muted:#5c6675;
    --line:#e3e7ee; --accent:#2f6df0; --accent-soft:#eaf1fe;
    --ok:#1f9d63; --warn:#c9781a; --bad:#c93838; --grid:#eef1f6;
  }
  @media (prefers-color-scheme: dark){
    :root{ --bg:#0e1218; --panel:#161b23; --ink:#e8ecf3; --muted:#97a2b3;
      --line:#242c38; --accent:#5b8def; --accent-soft:#18233b;
      --ok:#37c07f; --warn:#e0972f; --bad:#e5645a; --grid:#1c232e; }
  }
  :root[data-theme="dark"]{ --bg:#0e1218; --panel:#161b23; --ink:#e8ecf3; --muted:#97a2b3;
    --line:#242c38; --accent:#5b8def; --accent-soft:#18233b;
    --ok:#37c07f; --warn:#e0972f; --bad:#e5645a; --grid:#1c232e; }
  :root[data-theme="light"]{ --bg:#f7f8fa; --panel:#ffffff; --ink:#1a2230; --muted:#5c6675;
    --line:#e3e7ee; --accent:#2f6df0; --accent-soft:#eaf1fe;
    --ok:#1f9d63; --warn:#c9781a; --bad:#c93838; --grid:#eef1f6; }
  *{ box-sizing:border-box; }
  body{ margin:0; background:var(--bg); color:var(--ink);
    font:15px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif; }
  header{ padding:22px 28px 10px; }
  h1{ font-size:20px; margin:0 0 2px; font-weight:640; letter-spacing:-0.01em; }
  .sub{ color:var(--muted); font-size:13px; }
  .wrap{ display:grid; grid-template-columns:320px 1fr; gap:18px; padding:14px 28px 40px; }
  @media (max-width:1024px){ .wrap{ grid-template-columns:1fr; } }
  .panel{ background:var(--panel); border:1px solid var(--line); border-radius:12px; padding:18px; }
  .panel h2{ font-size:12px; text-transform:uppercase; letter-spacing:0.06em;
    color:var(--muted); margin:0 0 14px; font-weight:650; }
  .ctrl{ margin-bottom:16px; }
  .ctrl label{ display:flex; justify-content:space-between; font-size:13px; margin-bottom:6px; }
  .ctrl label .val{ font-variant-numeric:tabular-nums; color:var(--accent); font-weight:600; }
  input[type=range]{ width:100%; accent-color:var(--accent); }
  select,input[type=number]{ width:100%; padding:7px 9px; border:1px solid var(--line);
    border-radius:8px; background:var(--bg); color:var(--ink); font-size:14px; }
  .seg{ display:flex; border:1px solid var(--line); border-radius:8px; overflow:hidden; }
  .seg button{ flex:1; border:0; background:var(--panel); color:var(--muted);
    padding:7px 4px; font-size:13px; cursor:pointer; }
  .seg button.on{ background:var(--accent); color:#fff; font-weight:600; }
  .grid-out{ display:grid; grid-template-columns:1fr 1fr; gap:18px; }
  @media (max-width:720px){ .grid-out{ grid-template-columns:1fr; } }
  .span2{ grid-column:1 / -1; }
  .hero{ display:flex; align-items:baseline; gap:14px; flex-wrap:wrap; }
  .hero .lod{ font-size:44px; font-weight:700; letter-spacing:-0.02em; font-variant-numeric:tabular-nums; }
  .pill{ padding:3px 10px; border-radius:999px; font-size:13px; font-weight:650; }
  .pill.pass{ background:color-mix(in srgb,var(--ok) 16%,transparent); color:var(--ok); }
  .pill.miss{ background:color-mix(in srgb,var(--bad) 16%,transparent); color:var(--bad); }
  .hero .note{ color:var(--muted); font-size:13px; width:100%; }
  .bars{ margin-top:6px; }
  .bar-row{ display:flex; align-items:center; gap:10px; margin:8px 0; font-size:13px; }
  .bar-row .k{ width:96px; color:var(--muted); }
  .bar-track{ flex:1; height:16px; background:var(--grid); border-radius:5px; overflow:hidden; }
  .bar-fill{ height:100%; border-radius:5px; }
  .bar-row .v{ width:96px; text-align:right; font-variant-numeric:tabular-nums; }
  .interp{ font-size:14px; line-height:1.6; }
  .lever{ font-size:14px; margin:7px 0; padding-left:16px; position:relative; }
  .lever::before{ content:"→"; position:absolute; left:0; color:var(--accent); }
  .lever.no::before{ content:"✕"; color:var(--bad); }
  .banner{ border-radius:10px; padding:12px 14px; font-size:14px; font-weight:560; margin-bottom:16px; display:none; }
  .banner.floor{ background:color-mix(in srgb,var(--bad) 14%,transparent); color:var(--bad);
    border:1px solid color-mix(in srgb,var(--bad) 35%,transparent); }
  .banner.drift{ background:color-mix(in srgb,var(--bad) 18%,transparent); color:var(--bad);
    border:1px solid var(--bad); }
  .plot{ width:100%; height:320px; }
  .foot{ color:var(--muted); font-size:12px; padding:0 28px 30px; }
  .foot a{ color:var(--accent); text-decoration:none; }
  .foot a:hover{ text-decoration:underline; }
  code{ background:var(--grid); padding:1px 5px; border-radius:4px; font-size:12px; }
  /* Hover glossary: any [data-tip] term gets a dotted underline + explanation. */
  .term{ border-bottom:1px dashed var(--muted); cursor:help; }
  h2 .term{ border-bottom-color:var(--line); }
  .pill.term, .bar-row .k.term{ border-bottom:0; }
  .bar-row .k.term{ text-decoration:underline dotted; text-underline-offset:3px; cursor:help; }
  #tip{ position:fixed; z-index:1000; max-width:320px; padding:10px 12px; border-radius:9px;
    background:#111722; color:#eef2f8; border:1px solid #2b3442;
    box-shadow:0 8px 26px rgba(0,0,0,0.32); font-size:13px; line-height:1.45;
    pointer-events:none; opacity:0; transition:opacity .1s; }
  #tip .tip-title{ font-weight:680; margin-bottom:3px; color:#fff; }
  @media (prefers-color-scheme: light){
    #tip{ background:#1c2330; color:#eef2f8; border-color:#2b3442; }
  }
  /* Print / PDF: drop the control panel and stack the outputs full-width (P3.4). */
  @media print{
    :root{ --bg:#fff; --panel:#fff; --ink:#000; --line:#ccc; }
    #controls{ display:none !important; }
    .wrap{ grid-template-columns:1fr !important; padding:0 16px; }
    .grid-out{ grid-template-columns:1fr !important; }
    .panel{ break-inside:avoid; border:1px solid #ddd; }
    header{ padding:12px 16px 4px; }
  }
</style>
</head>
<body>
<header>
  <h1>ctDNA MRD — limit-of-detection design tool</h1>
  <div class="sub">Scenario <strong>{{ name }}</strong> · live analytic model · all levels shown as
    <strong class="term" data-tip-title="Tumour fraction (TF)" data-tip="The fraction of all DNA in the blood sample that came from the tumour. This is the clinically meaningful number — how much tumour signal is present. MRD assays chase values of a few parts per million.">tumour fraction (TF)</strong>
    unless axis-labelled <span class="term" data-tip-title="VAF (variant allele fraction)" data-tip="The fraction of molecules at one specific site that carry the mutation. For a typical heterozygous mutation, VAF = TF ÷ 2. The model works internally in VAF; the interface shows TF.">VAF</span>
    · numbers are <span class="term" data-tip-title="Order-of-magnitude priors" data-tip="The default values are rough estimates drawn from the published literature, not measurements from any specific assay. Use them to explore the design space, then replace them with your own data via the calibrate step.">order-of-magnitude priors</span>, not measurements.</div>
</header>

<div id="drift" class="banner drift"></div>

<div class="wrap">
  <!-- CONTROLS -->
  <div class="panel" id="controls">
    <h2>Assay configuration</h2>
    <div class="ctrl" id="presetWrap" style="display:none">
      <label><span class="term" data-tip-title="Scenario preset" data-tip="Pre-built example configurations (conservative, default, optimistic). Pick one to set every control at once, then fine-tune. Editing any control switches this back to ‘custom’.">Scenario preset</span></label>
      <select id="preset"></select>
    </div>
    <div class="ctrl">
      <label><span class="term" data-tip-title="cfDNA input" data-tip="How much cell-free DNA (in nanograms) you load into the assay. More input means more copies of the genome to search, so more chances to catch a rare tumour molecule. A typical blood draw yields roughly 5–50 ng.">cfDNA input</span> <span class="val"><span id="inV"></span> ng</span></label>
      <input type="range" id="input_ng" min="5" max="100" step="1">
    </div>
    <div class="ctrl">
      <label><span class="term" data-tip-title="Conversion efficiency" data-tip="The fraction of input DNA molecules that survive library preparation and become usable, error-corrected reads. Most molecules are lost on the way — typically only 20–60% make it. This is the most commonly overestimated parameter and a frequent reason real-world sensitivity disappoints.">Conversion efficiency</span> <span class="val"><span id="convV"></span>%</span></label>
      <input type="range" id="conv" min="10" max="90" step="1">
    </div>
    <div class="ctrl">
      <label><span class="term" data-tip-title="Panel size (N)" data-tip="How many tumour-specific mutations you track for this patient. Each tracked mutation is an independent chance to spot residual disease, so a larger, well-chosen panel can detect lower tumour levels. Shown on a log scale from 10 to 5,000.">Panel size (N, log)</span> <span class="val"><span id="nV"></span></span></label>
      <input type="range" id="nlog" min="1" max="3.699" step="0.01">
    </div>
    <div class="ctrl">
      <label><span class="term" data-tip-title="Error regime" data-tip="How aggressively the chemistry suppresses background noise — false ‘mutations’ introduced by sequencing itself — and how many molecules survive it. Each button sets both a typical error rate and a typical molecule retention (strand recovery).">Error regime</span></label>
      <div class="seg" id="regime">
        <button data-r="RAW" data-tip-title="Raw" data-tip="No error correction. About 1 false base in every 1,000 — far too noisy to see rare tumour DNA on its own. Keeps all molecules.">Raw</button>
        <button data-r="SSCS" data-tip-title="SSCS — single-strand consensus" data-tip="Reads from the same original molecule are grouped by a molecular barcode (UMI) and merged into one agreed call, cancelling random errors. About 1 error in 100,000. Keeps all molecules.">SSCS</button>
        <button data-r="DUPLEX" data-tip-title="Duplex (conventional)" data-tip="A base is trusted only when BOTH strands of the original molecule agree — about 1 error in 10,000,000. In conventional duplex the two strands come apart during library prep and must be re-paired afterwards, so you keep only about half the molecules (strand recovery ≈ 0.5).">Duplex</button>
        <button data-r="LINKED_DUPLEX" data-tip-title="Linked duplex (CODEC-type)" data-tip="Same both-strand error suppression as duplex (~1 in 10,000,000), but the two strands are physically joined before they can come apart, so far more molecules survive (strand recovery ≈ 0.8). The molecule cost of duplex is an implementation detail, not a law — this is the point. Ref: Yin et al., Nature Genetics 2023.">Linked</button>
        <button data-r="CUSTOM" data-tip-title="Custom" data-tip="Set the background error rate and strand recovery yourself with the sliders — the two axes are independent, so you can place any both-strand chemistry here.">Custom</button>
      </div>
    </div>
    <div class="ctrl" id="customWrap" style="display:none">
      <label><span class="term" data-tip-title="Custom ε (background error)" data-tip="Your own per-base background error rate, on a log scale. 10⁻⁵ means one false mutant base in every 100,000 bases sequenced.">Custom ε (log)</span> <span class="val">10<sup><span id="epsExpV"></span></sup></span></label>
      <input type="range" id="epslog" min="-8" max="-2" step="0.05">
    </div>
    <div class="ctrl">
      <label><span class="term" data-tip-title="Strand recovery" data-tip="The fraction of molecules that survive the chemistry — an axis independent of error rate. Single-strand methods keep everything (1.0). Conventional duplex loses about half re-pairing strands (0.5). Linked duplex keeps most of them (~0.8) at the same low error. Presets set a typical value; drag to model any point.">Strand recovery</span> <span class="val"><span id="strandV"></span>×</span></label>
      <input type="range" id="strand" min="0.1" max="1" step="0.05">
      <div class="sub" style="margin-top:4px">Molecule retention — independent of the error rate.
        1.0× keeps all molecules; conventional duplex ~0.5×; linked duplex ~0.8×. Set by the regime,
        overridable here (moving it switches the regime to Custom).</div>
    </div>
    <div class="ctrl">
      <label><span class="term" data-tip-title="Target specificity" data-tip="How sure you want to be that a ‘positive’ result is not a false alarm. 99% means at most 1 in 100 truly tumour-free samples is wrongly flagged positive. A stricter bar demands more evidence, which slightly raises (worsens) the detection limit.">Target specificity</span></label>
      <select id="spec">
        <option value="0.95">95%</option>
        <option value="0.99" selected>99%</option>
        <option value="0.995">99.5%</option>
        <option value="0.999">99.9%</option>
      </select>
    </div>
    <div class="ctrl">
      <label><span class="term" data-tip-title="Detection rule" data-tip="The statistical method used to decide ‘is tumour DNA present?’. Aggregate Poisson pools every mutant molecule across the panel and tests the total against expected noise. k-of-N judges each mutation on its own and calls the sample positive if at least k light up (the Signatera style).">Detection rule</span></label>
      <select id="rule">
        <option value="aggregate" title="Pool all mutant molecules across the panel and test the total against expected background. Efficient and simple.">Aggregate Poisson</option>
        <option value="kofn" title="Judge each tracked mutation individually; call the sample positive if at least k of them are significant. Intuitive and robust (Signatera-style).">k-of-N (Signatera-style)</option>
      </select>
    </div>
    <div class="ctrl">
      <label><span class="term" data-tip-title="Target LoD" data-tip="The detection limit you are aiming for, written as a percentage of tumour fraction (0.001% = 10 ppm). Smaller means you want to detect less tumour DNA — a harder goal. The hero readout turns green when the design reaches it.">Target LoD</span> <span class="val">% TF</span></label>
      <input type="text" id="target" lang="en-US" inputmode="decimal" autocomplete="off">
      <div class="sub" id="targetVafNote" style="margin-top:5px"></div>
    </div>
  </div>

  <!-- OUTPUTS -->
  <div class="grid-out">
    <div class="panel span2">
      <div id="floor" class="banner floor"></div>
      <h2><span class="term" data-tip-title="Achievable limit of detection (LoD)" data-tip="The lowest tumour fraction this design can reliably detect, at the stated detection rate (95%) and specificity. Lower is more sensitive. Shown as tumour fraction in parts per million.">Achievable limit of detection</span></h2>
      <div class="hero">
        <div class="lod" id="lodOut">—</div>
        <div class="pill term" id="passPill" data-tip-title="Meets / misses target" data-tip="Green when the achievable LoD is at or below your Target LoD, red when it falls short. When it misses, the ‘What would it take?’ panel lists the smallest change that would fix it.">—</div>
        <div class="note" id="lodNote"></div>
      </div>
    </div>

    <div class="panel">
      <h2><span class="term" data-tip-title="Molecule budget" data-tip="A head-count of the molecules in play at your target level: how many genuine tumour (‘mutant’) molecules you expect to see versus how many false (‘background’) molecules from noise. If mutant molecules do not comfortably outnumber background, detection is not physically possible — this is the most intuitive check in the tool.">Molecule budget</span> at target</h2>
      <div class="bars">
        <div class="bar-row"><div class="k term" data-tip-title="Mutant molecules" data-tip="The expected number of genuine tumour-derived mutant molecules present in the tube at the target level. If this is below ~3, the molecules simply are not there to be found, whatever you do downstream.">Mutant</div>
          <div class="bar-track"><div class="bar-fill" id="mutBar" style="background:var(--accent)"></div></div>
          <div class="v" id="mutV"></div></div>
        <div class="bar-row"><div class="k term" data-tip-title="Background molecules" data-tip="The expected number of fake mutant molecules produced by sequencing and chemistry noise at the target level. Lower-error regimes (SSCS, Duplex) shrink this number.">Background</div>
          <div class="bar-track"><div class="bar-fill" id="bgBar" style="background:var(--muted)"></div></div>
          <div class="v" id="bgV"></div></div>
      </div>
      <div class="sub" id="ratioV" style="margin-top:8px"></div>
    </div>

    <div class="panel">
      <h2><span class="term" data-tip-title="Effective genome equivalents" data-tip="How many complete copies of the genome you actually end up examining after all molecule losses. One genome equivalent is the DNA in a single cell (~3.3 pg). This is the true sample size that caps how low you can detect — extra sequencing cannot add molecules that were never in the tube.">Effective molecules</span></h2>
      <div class="interp" id="budgetProse"></div>
    </div>

    <div class="panel span2">
      <h2><span class="term" data-tip-title="Detection probability curve" data-tip="The chance the assay calls the sample positive, plotted against how much tumour DNA is present (in ppm tumour fraction). The dotted line marks the 95% detection level that defines the LoD; the green ✕ is the LoD itself.">Detection probability</span> vs tumour fraction (current settings)</h2>
      <div id="curve" class="plot"></div>
      <div class="sub" id="mcNote" style="margin-top:6px"></div>
    </div>

    <div class="panel span2">
      <h2><span class="term" data-tip-title="LoD surface" data-tip="A map of the achievable detection limit across every combination of panel size (left–right) and cfDNA input (bottom–top). The red line is your target; the white cross marks your current setting. Any design on the darker side of the red line reaches your goal.">LoD surface</span> — panel size × input mass</h2>
      <div id="surface" class="plot" style="height:380px"></div>
      <div class="sub">Analytic-valid regime: depth dispersion and site dropout are not modelled here.</div>
    </div>

    <div class="panel span2">
      <h2><span class="term" data-tip-title="Interpretation" data-tip="A plain-language summary of the current design: the achievable LoD, whether it meets the target, and which limit (too few molecules, or too much background) is holding it back.">Interpretation</span></h2>
      <div class="interp" id="interp"></div>
    </div>

    <div class="panel span2" id="wwitPanel">
      <h2><span class="term" data-tip-title="What would it take?" data-tip="When the design misses the target, this lists the smallest single change to each lever — panel size, cfDNA input, conversion efficiency, or error regime — that would reach it, holding everything else fixed. It also flags which changes are physically plausible.">What would it take?</span></h2>
      <div id="wwit"></div>
    </div>

    <div class="panel span2" id="powerPanel" style="display:none">
      <h2><span class="term" data-tip-title="Replicates per dilution level" data-tip="For a real validation study: how many repeat measurements at each dilution you would need to pin the detection limit down to a given precision. The confidence interval narrows roughly as 1 ÷ √(replicates).">Experimental design</span> — replicates per dilution level</h2>
      <div class="interp" id="powerBody"></div>
    </div>
  </div>
</div>

<div class="foot">
  Generated by <code>mrd-lod-sim</code> ·
  <a href="https://github.com/Qotov/mrd_lod" target="_blank" rel="noopener">source code on GitHub ↗</a>.
  The JS model reimplements the Python analytic path (BUILD_SPEC 4.2) and is checked on load against
  reference vectors from the package. Simulation is permanently necessary: real samples cannot provide
  ground truth at ppm.
</div>

<script>
const PAYLOAD = {{ payload_json | safe }};

// ---- analytic model (mirror of analytic.py) ----------------------------
const M = {
  lgamma(x){
    const c=[0.99999999999980993,676.5203681218851,-1259.1392167224028,
      771.32342877765313,-176.61502916214059,12.507343278686905,
      -0.13857109526572012,9.9843695780195716e-6,1.5056327351493116e-7];
    if(x<0.5) return Math.log(Math.PI/Math.sin(Math.PI*x))-this.lgamma(1-x);
    x-=1; let a=c[0]; const g=7, t=x+g+0.5;
    for(let i=1;i<9;i++) a+=c[i]/(x+i);
    return 0.5*Math.log(2*Math.PI)+(x+0.5)*Math.log(t)-t+Math.log(a);
  },
  // Inverse standard normal (Acklam) -- used to jump-start the threshold search.
  normPpf(p){
    const a=[-3.969683028665376e+01,2.209460984245205e+02,-2.759285104469687e+02,
      1.383577518672690e+02,-3.066479806614716e+01,2.506628277459239e+00];
    const b=[-5.447609879822406e+01,1.615858368580409e+02,-1.556989798598866e+02,
      6.680131188771972e+01,-1.328068155288572e+01];
    const c=[-7.784894002430293e-03,-3.223964580411365e-01,-2.400758277161838e+00,
      -2.549732539343734e+00,4.374664141464968e+00,2.938163982698783e+00];
    const d=[7.784695709041462e-03,3.224671290700398e-01,2.445134137142996e+00,3.754408661907416e+00];
    const pl=0.02425;
    if(p<pl){ const q=Math.sqrt(-2*Math.log(p));
      return (((((c[0]*q+c[1])*q+c[2])*q+c[3])*q+c[4])*q+c[5])/((((d[0]*q+d[1])*q+d[2])*q+d[3])*q+1); }
    if(p<=1-pl){ const q=p-0.5, r=q*q;
      return (((((a[0]*r+a[1])*r+a[2])*r+a[3])*r+a[4])*r+a[5])*q/(((((b[0]*r+b[1])*r+b[2])*r+b[3])*r+b[4])*r+1); }
    const q=Math.sqrt(-2*Math.log(1-p));
    return -(((((c[0]*q+c[1])*q+c[2])*q+c[3])*q+c[4])*q+c[5])/((((d[0]*q+d[1])*q+d[2])*q+d[3])*q+1);
  },
  // Regularised lower incomplete gamma P(a,x) (Numerical Recipes): O(tens),
  // stable for large x -- this is what makes the whole dashboard fast.
  gser(a,x){ if(x<=0) return 0; let ap=a,sum=1/a,del=1/a;
    for(let n=0;n<400;n++){ ap++; del*=x/ap; sum+=del; if(Math.abs(del)<Math.abs(sum)*1e-15) break; }
    return sum*Math.exp(-x+a*Math.log(x)-this.lgamma(a)); },
  gcf(a,x){ const F=1e-300; let b=x+1-a,c=1/F,d=1/b,h=d;
    for(let i=1;i<400;i++){ const an=-i*(i-a); b+=2; d=an*d+b; if(Math.abs(d)<F)d=F;
      c=b+an/c; if(Math.abs(c)<F)c=F; d=1/d; const del=d*c; h*=del; if(Math.abs(del-1)<1e-15) break; }
    return Math.exp(-x+a*Math.log(x)-this.lgamma(a))*h; },
  gammp(a,x){ if(x<=0||a<=0) return 0; return x<a+1 ? this.gser(a,x) : 1-this.gcf(a,x); },
  // Regularised incomplete beta I_x(a,b) (Numerical Recipes) for binomial tails.
  betacf(a,b,x){ const F=1e-300; let qab=a+b,qap=a+1,qam=a-1,c=1,d=1-qab*x/qap;
    if(Math.abs(d)<F)d=F; d=1/d; let h=d;
    for(let m=1;m<400;m++){ const m2=2*m;
      let aa=m*(b-m)*x/((qam+m2)*(a+m2)); d=1+aa*d; if(Math.abs(d)<F)d=F; c=1+aa/c; if(Math.abs(c)<F)c=F;
      d=1/d; h*=d*c; aa=-(a+m)*(qab+m)*x/((a+m2)*(qap+m2)); d=1+aa*d; if(Math.abs(d)<F)d=F;
      c=1+aa/c; if(Math.abs(c)<F)c=F; d=1/d; const del=d*c; h*=del; if(Math.abs(del-1)<1e-14) break; }
    return h; },
  betai(a,b,x){ if(x<=0) return 0; if(x>=1) return 1;
    const bt=Math.exp(this.lgamma(a+b)-this.lgamma(a)-this.lgamma(b)+a*Math.log(x)+b*Math.log1p(-x));
    return x<(a+1)/(a+b+2) ? bt*this.betacf(a,b,x)/a : 1-bt*this.betacf(b,a,1-x)/b; },
  // P(X>=t) for X~Poisson(lam)  ==  regularised lower incomplete gamma P(t,lam).
  poissonSfGe(t,lam){ if(t<=0) return 1; if(lam<=0) return 0; return this.gammp(t,lam); },
  poissonCdf(k,lam){ k=Math.floor(k); if(k<0) return 0; if(lam<=0) return 1; return 1-this.gammp(k+1,lam); },
  // P(K>=k) for K~Binomial(n,p)  ==  regularised incomplete beta I_p(k, n-k+1).
  binomSfGe(k,n,p){ k=Math.ceil(k); if(k<=0) return 1; if(k>n) return 0;
    if(p<=0) return 0; if(p>=1) return 1; return this.betai(k, n-k+1, p); },
  // Smallest count t with P(X>=t | Poisson(lamBg)) <= alpha. Jump-start near the
  // upper quantile via the normal approximation, then adjust by a few steps.
  countThreshold(lamBg,alpha){
    if(lamBg<=0) return 1;
    let t=Math.max(1, Math.floor(lamBg + this.normPpf(1-alpha)*Math.sqrt(lamBg)));
    while(t>1 && this.poissonSfGe(t-1,lamBg)<=alpha) t--;
    while(this.poissonSfGe(t,lamBg)>alpha) t++;
    return t;
  },
  geEff(s){ return s.input_ng/s.pg * s.conv * s.strand; },
  // Prepared context: the threshold depends only on the background (not VAF),
  // so compute it once and reuse it across a whole VAF sweep / bisection.
  prepAgg(s){ const ge=this.geEff(s), lamBg=ge*s.n*s.eps;
    return {ge,lamBg,t:this.countThreshold(lamBg,s.alpha)}; },
  aggP(c,s,vaf){ return this.poissonSfGe(c.t, c.lamBg + c.ge*s.n*vaf*s.e_ccf); },
  prepKofn(s){ const ge=this.geEff(s), lamB=ge*s.eps;
    return {ge,lamB,t:this.countThreshold(lamB,s.per_site_alpha)}; },
  kofnP(c,s,vaf){ return this.binomSfGe(s.k, s.n, this.poissonSfGe(c.t, c.lamB + c.ge*vaf*s.e_ccf)); },
  prep(s){ return s.rule==='kofn' ? {kofn:true,c:this.prepKofn(s)} : {kofn:false,c:this.prepAgg(s)}; },
  detectWith(p,s,vaf){ return p.kofn ? this.kofnP(p.c,s,vaf) : this.aggP(p.c,s,vaf); },
  aggregate(s,vaf){ return this.aggP(this.prepAgg(s),s,vaf); },
  detect(s,vaf){ return this.detectWith(this.prep(s),s,vaf); },
  achievableLod(s,hit){
    const p=this.prep(s); let lo=1e-9, hi=0.5;
    if(this.detectWith(p,s,hi)<hit) return Infinity;
    if(this.detectWith(p,s,lo)>=hit) return lo;
    for(let i=0;i<60;i++){ const mid=Math.sqrt(lo*hi);
      if(this.detectWith(p,s,mid)>=hit) hi=mid; else lo=mid; }
    return hi;
  }
};

// ---- golden-vector self-check (Python/JS drift guard, BUILD_SPEC 8.1) ---
(function(){
  let maxErr=0;
  for(const r of PAYLOAD.golden){
    const s={input_ng:r.input_ng,conv:r.conv,strand:r.strand,pg:r.pg,n:r.n,
      e_ccf:r.e_ccf,eps:r.eps,alpha:r.alpha,rule:'aggregate'};
    maxErr=Math.max(maxErr,Math.abs(M.aggregate(s,r.vaf)-r.p));
  }
  if(maxErr>1e-6){
    const b=document.getElementById('drift');
    b.style.display='block';
    b.textContent='⚠ JS analytic model diverges from the Python reference (max error '
      +maxErr.toExponential(2)+'). Do not trust these numbers.';
  } else { console.log('golden-vector check OK, max error '+maxErr.toExponential(2)); }
})();

// ---- state & helpers ---------------------------------------------------
const cur=PAYLOAD.current, tgt=PAYLOAD.target;
const $=id=>document.getElementById(id);
let state={
  input_ng:cur.input_ng, conv:cur.conversion_efficiency, strand:cur.strand_recovery,
  pg:cur.pg_per_ge, n:cur.n_variants, e_ccf:cur.e_ccf, eps:cur.eps,
  regime:regimeOf(cur.eps, cur.strand_recovery), spec:tgt.specificity, rule:PAYLOAD.meta.rule,
  k:cur.k, per_site_alpha:cur.per_site_alpha, targetTF:tgt.tf
};
// A regime is identified by BOTH axes (eps AND strand recovery), because
// conventional and linked duplex share the same eps and differ only in retention.
function regimeOf(eps, strand){
  for(const [k,v] of Object.entries(PAYLOAD.regime_presets)){
    if(Math.abs(eps-v.eps)/v.eps<0.01 && Math.abs(strand-v.strand)<0.02) return k;
  }
  return 'CUSTOM';
}
function ruleKey(name){ return name==='KofNRule'?'kofn':'aggregate'; }
state.rule=ruleKey(PAYLOAD.meta.rule);

const fmtPct=v=>{ // fraction -> "x ppm TF" or "%" sensibly
  const ppm=v*1e6;
  if(ppm<1) return (ppm*1000).toPrecision(2)+' ppb TF';
  if(ppm<1000) return ppm.toPrecision(3)+' ppm TF';
  return (v*100).toPrecision(3)+'% TF';
};
// Plain decimals over the whole display range a wet-lab reader parses at a
// glance (0.18, not 1.82e-1); exponential only for the genuinely tiny.
const fmtNum=v=>{
  if(v===0) return '0';
  if(v>=100) return Math.round(v).toLocaleString('en-US');
  if(v>=1) return String(+v.toPrecision(3));
  if(v>=0.001) return String(+v.toPrecision(2));
  return v.toExponential(2);
};

// settings object for the model (VAF space). alpha = 1 - specificity.
function modelSettings(){
  return {input_ng:state.input_ng,conv:state.conv,strand:state.strand,pg:state.pg,
    n:state.n,e_ccf:state.e_ccf,eps:state.eps,alpha:1-state.spec,rule:state.rule,
    k:state.k,per_site_alpha:state.per_site_alpha};
}
const tfToVaf=tf=>tf/2, vafToTf=v=>v*2;

// ---- render ------------------------------------------------------------
function render(){
  const s=modelSettings();
  const hit=tgt.hit_rate;
  const lodVaf=M.achievableLod(s,hit);
  const lodTF=vafToTf(lodVaf);
  const targetVaf=tfToVaf(state.targetTF);

  // hero
  $('lodOut').textContent = isFinite(lodVaf)? fmtPct(lodTF) : 'unreachable';
  const pass = isFinite(lodVaf) && lodTF<=state.targetTF*1.0001;
  const pill=$('passPill');
  pill.textContent = pass? 'MEETS TARGET':'MISSES TARGET';
  pill.className='pill '+(pass?'pass':'miss');
  $('lodNote').textContent =
    `at ${(hit*100).toFixed(0)}% detection and ${(state.spec*100).toFixed(1)}% specificity · `+
    `target ${fmtPct(state.targetTF)} · LoD shown as TF (VAF = TF/2)`;

  // molecule budget at target
  const ge=M.geEff(s);
  const mut=ge*s.n*targetVaf*s.e_ccf, bg=ge*s.n*s.eps;
  const mx=Math.max(mut,bg,1e-9);
  $('mutBar').style.width=(100*mut/mx)+'%';
  $('bgBar').style.width=(100*bg/mx)+'%';
  $('mutV').textContent=fmtNum(mut)+' molecules';
  $('bgV').textContent=fmtNum(bg)+' molecules';
  $('ratioV').textContent=`signal:background ≈ ${(mut/Math.max(bg,1e-9)).toPrecision(2)} : 1  ·  `+
    `${fmtNum(ge)} effective GE interrogated`;

  // poisson floor
  const floor=$('floor');
  if(mut<3){ floor.style.display='block';
    floor.textContent=`Below the sampling floor — expected mutant molecules ≈ ${mut.toPrecision(2)} (<3). `+
      `The molecules are not present in the sample; no additional sequencing depth can recover this.`;
  } else floor.style.display='none';

  // budget prose
  $('budgetProse').innerHTML =
    `At <b>${fmtNum(state.input_ng)} ng</b> input with <b>${Math.round(state.conv*100)}%</b> conversion you `+
    `interrogate <b>${fmtNum(ge)}</b> effective genome equivalents. Across <b>${fmtNum(state.n)}</b> tracked `+
    `variants at ${fmtPct(state.targetTF)} you expect <b>${fmtNum(mut)}</b> mutant vs <b>${fmtNum(bg)}</b> `+
    `background molecules.`;

  drawCurve(s,lodVaf,hit);
  drawSurface(s,hit);
  drawInterp(s,lodTF,pass,mut,bg);
  drawWwit(s,targetVaf,hit,pass);
  renderPower(lodTF*1e6);
  stateToHash();
}

// The Monte Carlo overlay is a STATIC array baked in at generation time. Only
// show it when the live UI settings match exactly what it was generated under --
// otherwise the two curves are computed at different thresholds and disagree for
// reasons that are not Monte Carlo error (BUILD_SPEC review P0.2).
function mcMatches(s){
  const g=PAYLOAD.mc_settings; if(!g) return false;
  const near=(a,b)=>Math.abs(a-b)<=1e-9*Math.max(1,Math.abs(b));
  const base = s.rule===g.rule && s.n===g.n_variants && near(s.input_ng,g.input_ng)
    && near(s.conv,g.conversion_efficiency) && near(s.strand,g.strand_recovery)
    && near(s.eps,g.eps) && near(s.e_ccf,g.e_ccf) && near(s.alpha,g.alpha);
  return base && (s.rule!=='kofn' || (s.k===g.k && near(s.per_site_alpha,g.per_site_alpha)));
}
const vafToPpm=v=>v*2e6;  // per-site VAF -> ppm tumour fraction (TF = 2*VAF)
function drawCurve(s,lodVaf,hit){
  const xs=[], ys=[];
  const centre = isFinite(lodVaf)? lodVaf : tfToVaf(state.targetTF);
  const lo=Math.log10(centre/60), hi=Math.log10(centre*60);
  const p=M.prep(s);  // threshold computed once, reused across the sweep
  for(let i=0;i<=60;i++){ const v=Math.pow(10,lo+(hi-lo)*i/60); xs.push(vafToPpm(v)); ys.push(M.detectWith(p,s,v)); }
  const traces=[
    {x:xs,y:ys,mode:'lines',name:'analytic',line:{color:'#2f6df0',width:2.5},
      hovertemplate:'%{x:.3g} ppm TF → P=%{y:.3f}<extra></extra>'}
  ];
  const show=mcMatches(s);
  if(show){ const mc=PAYLOAD.mc_curve;
    traces.push({x:mc.map(d=>vafToPpm(d.vaf)),y:mc.map(d=>d.p),mode:'markers',name:'Monte Carlo',
      marker:{color:'#c9781a',size:6,symbol:'circle-open'},
      hovertemplate:'Monte Carlo: %{x:.3g} ppm TF → %{y:.3f}<extra></extra>'});
  }
  if(isFinite(lodVaf)) traces.push({x:[vafToPpm(lodVaf)],y:[hit],mode:'markers',name:'LoD',
    marker:{color:'#1f9d63',size:11,symbol:'x'},hovertemplate:'LoD %{x:.3g} ppm TF<extra></extra>'});
  Plotly.react('curve',traces,{
    margin:{l:52,r:12,t:8,b:44}, paper_bgcolor:'transparent', plot_bgcolor:'transparent',
    font:{color:getCss('--ink')}, showlegend:true, legend:{orientation:'h',y:1.12},
    xaxis:{type:'log',title:'tumour fraction (ppm)',gridcolor:getCss('--grid')},
    yaxis:{title:'P(detect)',range:[0,1.02],gridcolor:getCss('--grid')},
    shapes:[{type:'line',x0:xs[0],x1:xs[xs.length-1],y0:hit,y1:hit,
      line:{color:getCss('--muted'),dash:'dot',width:1}}]
  },{displayModeBar:false,responsive:true});
  const g=PAYLOAD.mc_settings;
  $('mcNote').textContent = show
    ? 'Monte Carlo overlay (orange) validates the analytic curve at the current settings.'
    : (g? `Monte Carlo overlay shown only at its generation settings (N=${g.n_variants}, ${g.regime_label}, `
        + `${((1-g.alpha)*100).toFixed(1)}% specificity, ${g.rule} rule) — change settings back to see it.` : '');
}

// The surface grid depends only on conversion, error, rule and specificity --
// NOT on input mass or panel size (those only move the crosshair). Cache Z and
// recompute it only when a dependency changes, so dragging the input/panel
// sliders is instant. The recompute itself is debounced off the frame loop so
// that even the conversion/error sliders stay responsive while the grid catches
// up (the crosshair and every other panel update immediately from cached Z).
let _surf={sig:null,z:null,nGrid:null,mGrid:null};
let _surfTimer=null;
function surfaceSig(s,hit){ return [s.conv,s.eps,s.rule,s.alpha,s.k,s.per_site_alpha,hit].join('|'); }
function computeSurfaceZ(s,hit,sig){
  const nGrid=[], mGrid=[], Z=[];
  for(let i=0;i<16;i++) nGrid.push(Math.round(Math.pow(10,1+(3.699-1)*i/15)));
  for(let j=0;j<16;j++) mGrid.push(5+(100-5)*j/15);
  for(const m of mGrid){ const row=[];
    for(const n of nGrid){ const ss=Object.assign({},s,{input_ng:m,n:n});
      const lod=M.achievableLod(ss,hit);
      row.push(isFinite(lod)? Math.log10(vafToTf(lod)) : null); }
    Z.push(row); }
  _surf={sig,z:Z,nGrid,mGrid};
}
function plotSurface(){
  if(!_surf.z) return;
  const Z=_surf.z, nGrid=_surf.nGrid, mGrid=_surf.mGrid;
  // customdata carries the LoD in human units (ppm TF) for the hover, while the
  // z scale stays log10 for its dynamic range but is TICK-labelled in ppm.
  const ppm=Z.map(row=>row.map(z=> z==null? null : Math.pow(10,z)*1e6));
  const targetPpm=state.targetTF*1e6;
  Plotly.react('surface',[{
    z:Z,x:nGrid,y:mGrid,type:'contour',colorscale:'Viridis',name:'LoD',
    customdata:ppm,
    hovertemplate:'panel N=%{x:.0f} × %{y:.0f} ng → <b>%{customdata:.1f} ppm TF</b><extra></extra>',
    colorbar:{title:'LoD (ppm TF)',titleside:'right',
      tickvals:[-3,-4,-5,-6], ticktext:['1000 ppm','100 ppm','10 ppm','1 ppm']},
    contours:{coloring:'heatmap'}
  },{
    x:[state.n],y:[state.input_ng],mode:'markers',type:'scatter',name:'current setting',
    marker:{color:'#fff',size:12,symbol:'cross-thin',line:{color:'#000',width:2}},
    hovertemplate:'current: N=%{x:.0f}, %{y:.0f} ng<extra></extra>'
  },{
    z:Z,x:nGrid,y:mGrid,type:'contour',showscale:false,
    name:`${targetPpm.toPrecision(3)} ppm TF target`, hoverinfo:'name',
    contours:{start:Math.log10(state.targetTF),end:Math.log10(state.targetTF),
      coloring:'lines'}, line:{color:'#c93838',width:2.5}
  }],{
    margin:{l:66,r:12,t:8,b:46}, paper_bgcolor:'transparent', plot_bgcolor:'transparent',
    font:{color:getCss('--ink')}, showlegend:false,
    xaxis:{type:'log',title:'panel size (N)'}, yaxis:{title:'cfDNA input (ng)'}
  },{displayModeBar:false,responsive:true});
}
function drawSurface(s,hit){
  const sig=surfaceSig(s,hit);
  if(!_surf.z){ computeSurfaceZ(s,hit,sig); plotSurface(); return; }  // first paint
  plotSurface();                                                     // crosshair/contour now
  if(_surf.sig!==sig){                                               // grid stale -> debounce
    const ss=Object.assign({},s);
    if(_surfTimer) clearTimeout(_surfTimer);
    _surfTimer=setTimeout(()=>{ computeSurfaceZ(ss,hit,sig); plotSurface(); }, 90);
  }
}

function drawInterp(s,lodTF,pass,mut,bg){
  let msg=`This configuration achieves an LoD of <b>${fmtPct(lodTF)}</b>. `;
  if(pass) msg+=`That <b>meets</b> the ${fmtPct(state.targetTF)} target. `;
  else msg+=`That <b>misses</b> the ${fmtPct(state.targetTF)} target. `;
  if(mut<3) msg+=`Expected mutant molecules (${mut.toPrecision(2)}) are below the sampling floor — the limit is the sample, not the sequencer. `;
  else if(bg>mut) msg+=`Background (${fmtNum(bg)} molecules) exceeds signal (${fmtNum(mut)} molecules) at target; a lower-error regime would help most. `;
  else msg+=`Signal comfortably exceeds background at target. `;
  $('interp').innerHTML=msg;
}

function drawWwit(s,targetVaf,hit,pass){
  const panel=$('wwitPanel');
  if(pass){ panel.style.display='none'; return; }
  panel.style.display='block';
  const out=[];
  // one lever at a time (mirror of surface.what_would_it_take)
  out.push(lever('Panel size', s,'n', state.n, 100000, 5000, v=>Math.ceil(v)+' variants', targetVaf,hit,true));
  out.push(lever('cfDNA input', s,'input_ng', state.input_ng, 1000, 100, v=>Math.round(v)+' ng', targetVaf,hit,true));
  out.push(lever('Conversion', s,'conv', state.conv, 0.9, 0.9, v=>Math.round(v*100)+'%', targetVaf,hit,true));
  out.push(leverEps(s,targetVaf,hit));
  $('wwit').innerHTML=`<div class="sub" style="margin-bottom:8px">Minimum change in each single lever (others held fixed):</div>`+out.join('');
}
function lever(name,s,key,cur0,max,plaus,fmt,targetVaf,hit,incr){
  const meets=x=>{const ss=Object.assign({},s);ss[key]=key==='n'?Math.ceil(x):x;return M.detect(ss,targetVaf)>=hit;};
  if(meets(cur0)) return `<div class="lever">${name}: already sufficient</div>`;
  if(!meets(max)) return `<div class="lever no">${name}: cannot reach the target alone</div>`;
  let lo=cur0,hi=max; for(let i=0;i<80;i++){const mid=(lo+hi)/2; if(meets(mid))hi=mid;else lo=mid;}
  const ok=hi<=plaus;
  return `<div class="lever${ok?'':' no'}">${name}: ${fmt(hi)}${ok?'':' (beyond a plausible range)'}</div>`;
}
function leverEps(s,targetVaf,hit){
  const meets=e=>M.detect(Object.assign({},s,{eps:e}),targetVaf)>=hit;
  if(meets(s.eps)) return `<div class="lever">Error regime: already sufficient</div>`;
  if(!meets(1e-9)) return `<div class="lever no">Error regime: cannot reach the target alone</div>`;
  let lo=1e-9,hi=s.eps; for(let i=0;i<80;i++){const mid=Math.sqrt(lo*hi); if(meets(mid))lo=mid;else hi=mid;}
  let named=null;
  for(const [k,v] of Object.entries(PAYLOAD.regimes).sort((a,b)=>b[1]-a[1])) if(v<=lo){named=k;break;}
  return `<div class="lever${named?'':' no'}">Error regime: reduce ε to ≤ ${lo.toExponential(1)}`+
    (named?` (the ${named} regime reaches this)`:` (below any named regime)`)+`</div>`;
}

function getCss(v){ return getComputedStyle(document.documentElement).getPropertyValue(v).trim(); }

// Locale-robust numeric parse: accept both '.' and ',' decimal separators.
function parseNum(str){ const v=parseFloat(String(str).replace(',','.')); return v; }

// ---- scenario presets (P3.2) -------------------------------------------
function populatePresets(){
  const ps=PAYLOAD.presets||[]; if(!ps.length) return;
  const sel=$('preset'); $('presetWrap').style.display='block';
  sel.innerHTML='<option value="">— custom —</option>'+
    ps.map(p=>`<option value="${p.name}">${p.name}</option>`).join('');
  sel.value = ps.some(p=>p.name===PAYLOAD.meta.name)? PAYLOAD.meta.name : '';
  sel.onchange=e=>{ const p=ps.find(x=>x.name===e.target.value); if(p) applyPreset(p); };
}
function applyPreset(p){
  state.input_ng=p.input_ng; state.conv=p.conv; state.strand=p.strand;
  state.n=p.n; state.eps=p.eps; state.spec=p.spec; state.rule=p.rule; state.targetTF=p.targetTF;
  state.regime=regimeOf(p.eps, p.strand);
  syncInputs(); schedule();
}
function markCustom(){ const s=$('preset'); if(s) s.value=''; }

// ---- experimental-design (power) panel (P3.1) --------------------------
// Live: the 95% CI half-width on a probit LoD estimate scales ~1/sqrt(n) and
// ~linearly with the LoD, so we scale the bootstrapped RELATIVE half-widths by
// the current LoD. The panel then always agrees with the hero above it.
function renderPower(lodPpm){
  const pw=PAYLOAD.power, panel=$('powerPanel');
  if(!pw || !isFinite(lodPpm)){ panel.style.display='none'; return; }
  panel.style.display='block';
  const tr=pw.target_rel;
  const req=(pw.grid.find(g=>g.rel!=null && g.rel<=tr)||{}).n;
  const rows=pw.grid.map(g=>
    `<tr><td style="text-align:right;padding:2px 14px">${g.n}</td>`+
    `<td style="padding:2px 14px">${g.rel==null?'—':'±'+fmtNum(g.rel*lodPpm)+' ppm TF ('
      +'±'+Math.round(g.rel*100)+'%)'}</td></tr>`).join('');
  const lead = req
    ? `To pin this LoD (≈${fmtNum(lodPpm)} ppm TF) to within ±${Math.round(tr*100)}% `+
      `(±${fmtNum(tr*lodPpm)} ppm TF), you need about <b>${req} replicates</b> per dilution level.`
    : `Reaching ±${Math.round(tr*100)}% of this LoD needs more than `+
      `${pw.grid[pw.grid.length-1].n} replicates per dilution level.`;
  $('powerBody').innerHTML = lead +
    `<table style="margin-top:10px;border-collapse:collapse;font-size:13px">`+
    `<tr><th style="text-align:right;padding:2px 14px">replicates / level</th>`+
    `<th style="text-align:left;padding:2px 14px">LoD 95% CI half-width</th></tr>${rows}</table>`+
    `<div class="sub" style="margin-top:8px">Scales with the current LoD; replicate counts assume the `+
    `detection-curve sharpness of the reference fit. Sizes the real dilution study.</div>`;
}

// ---- shareable URL state (P3.3) ----------------------------------------
function stateToHash(){
  const p=new URLSearchParams();
  p.set('in',state.input_ng); p.set('cv',state.conv); p.set('n',state.n);
  p.set('eps',state.eps); p.set('st',state.strand); p.set('sp',state.spec);
  p.set('rl',state.rule); p.set('tf',state.targetTF);
  history.replaceState(null,'','#'+p.toString());
}
function hashToState(){
  if(!location.hash || location.hash.length<2) return;
  const p=new URLSearchParams(location.hash.slice(1));
  const num=(k,d)=>p.has(k)?parseFloat(p.get(k)):d;
  state.input_ng=num('in',state.input_ng); state.conv=num('cv',state.conv);
  state.n=Math.round(num('n',state.n)); state.eps=num('eps',state.eps);
  state.strand=num('st',state.strand);
  state.spec=num('sp',state.spec); state.rule=p.get('rl')||state.rule;
  state.targetTF=num('tf',state.targetTF); state.regime=regimeOf(state.eps, state.strand);
  markCustom();  // a shared link is, by definition, a custom configuration
}

// ---- wire controls -----------------------------------------------------
function setRegimeButtons(){
  document.querySelectorAll('#regime button').forEach(b=>
    b.classList.toggle('on', b.dataset.r===state.regime));
  $('customWrap').style.display = state.regime==='CUSTOM'?'block':'none';
}
function syncInputs(){
  $('input_ng').value=state.input_ng; $('inV').textContent=state.input_ng;
  $('conv').value=state.conv*100; $('convV').textContent=Math.round(state.conv*100);
  $('nlog').value=Math.log10(state.n); $('nV').textContent=fmtNum(state.n);
  $('strand').value=state.strand; $('strandV').textContent=(+state.strand.toFixed(2));
  $('spec').value=state.spec; $('rule').value=state.rule;
  // type=text field: set a dot-decimal string so it never renders 0,001 under
  // a comma-decimal browser locale.
  $('target').value=String(+(state.targetTF*100).toPrecision(4));
  $('targetVafNote').textContent=`= ${fmtPct(state.targetTF)}  ·  VAF = ${fmtPct(tfToVaf(state.targetTF)).replace(' TF','')} `;
  $('epslog').value=Math.log10(state.eps); $('epsExpV').textContent=Math.log10(state.eps).toFixed(1);
  setRegimeButtons();
}
let raf=null; function schedule(){ if(raf) cancelAnimationFrame(raf); raf=requestAnimationFrame(render); }

$('input_ng').oninput=e=>{state.input_ng=+e.target.value;$('inV').textContent=state.input_ng;markCustom();schedule();};
$('conv').oninput=e=>{state.conv=+e.target.value/100;$('convV').textContent=e.target.value;markCustom();schedule();};
$('nlog').oninput=e=>{state.n=Math.round(Math.pow(10,+e.target.value));$('nV').textContent=fmtNum(state.n);markCustom();schedule();};
$('spec').onchange=e=>{state.spec=+e.target.value;markCustom();schedule();};
$('rule').onchange=e=>{state.rule=e.target.value;markCustom();schedule();};
$('target').oninput=e=>{const v=parseNum(e.target.value); if(!isFinite(v)) return;
  state.targetTF=Math.max(0,v/100);
  $('targetVafNote').textContent=`= ${fmtPct(state.targetTF)}  ·  VAF = ${fmtPct(tfToVaf(state.targetTF)).replace(' TF','')} `;markCustom();schedule();};
// Moving either the error or the strand slider flips the regime to Custom: the
// two axes are now unlocked and no named preset owns the point.
$('epslog').oninput=e=>{state.eps=Math.pow(10,+e.target.value);$('epsExpV').textContent=(+e.target.value).toFixed(1);
  state.regime='CUSTOM'; setRegimeButtons(); markCustom(); schedule();};
$('strand').oninput=e=>{state.strand=+e.target.value;$('strandV').textContent=(+state.strand.toFixed(2));
  state.regime='CUSTOM'; setRegimeButtons(); markCustom(); schedule();};
document.querySelectorAll('#regime button').forEach(b=>b.onclick=()=>{
  state.regime=b.dataset.r;
  // A regime preset sets BOTH axes explicitly (error rate AND molecule
  // retention), from the Python source of truth -- no numbers hardcoded here.
  // Custom leaves both sliders as they are.
  const preset=(PAYLOAD.regime_presets||{})[state.regime];
  if(preset){ state.eps=preset.eps; state.strand=preset.strand; }
  setRegimeButtons(); markCustom(); syncInputs(); schedule();
});

// ---- hover glossary tooltips -------------------------------------------
// A single floating box, appended to <body> so it is never clipped by a panel.
const _tip=document.createElement('div'); _tip.id='tip'; document.body.appendChild(_tip);
function _showTip(el){
  _tip.innerHTML='';
  const title=document.createElement('div'); title.className='tip-title';
  title.textContent=el.dataset.tipTitle || el.textContent.trim();
  const body=document.createElement('div'); body.textContent=el.getAttribute('data-tip');
  _tip.append(title, body);
  _tip.style.opacity='1'; _tip.style.left='0px'; _tip.style.top='0px';  // measure
  const r=el.getBoundingClientRect(), tw=_tip.offsetWidth, th=_tip.offsetHeight;
  let left=Math.max(8, Math.min(r.left+r.width/2-tw/2, innerWidth-tw-8));
  let top=r.top-th-8; if(top<8) top=r.bottom+8;
  _tip.style.left=left+'px'; _tip.style.top=top+'px';
}
function _hideTip(){ _tip.style.opacity='0'; }
function initTooltips(){
  document.querySelectorAll('[data-tip]').forEach(el=>{
    el.tabIndex = el.tabIndex<0 ? 0 : el.tabIndex;  // keyboard-focusable
    el.addEventListener('mouseenter',()=>_showTip(el));
    el.addEventListener('mouseleave',_hideTip);
    el.addEventListener('focus',()=>_showTip(el));
    el.addEventListener('blur',_hideTip);
  });
}

populatePresets();
hashToState();
initTooltips();
syncInputs(); render();
</script>
</body>
</html>
