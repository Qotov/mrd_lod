<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>MRD LoD design tool — {{ name }}</title>
<!--
  Self-contained MRD limit-of-detection design tool (BUILD_SPEC 8).
  Plotly is loaded from CDN. To run fully offline, download plotly.min.js and
  replace the <script src="https://cdn.plot.ly/..."> tag below with an inline
  <script>…</script> containing its contents.
-->
<script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
<style>
  :root{
    --bg:#f7f8fa; --panel:#ffffff; --ink:#1a2230; --muted:#5c6675;
    --line:#e3e7ee; --accent:#2f6df0; --accent-soft:#eaf1fe;
    --ok:#1f9d63; --warn:#c9781a; --bad:#c93838; --grid:#eef1f6;
  }
  @media (prefers-color-scheme: dark){
    :root{ --bg:#0e1218; --panel:#161b23; --ink:#e8ecf3; --muted:#97a2b3;
      --line:#242c38; --accent:#5b8def; --accent-soft:#18233b;
      --ok:#37c07f; --warn:#e0972f; --bad:#e5645a; --grid:#1c232e; }
  }
  :root[data-theme="dark"]{ --bg:#0e1218; --panel:#161b23; --ink:#e8ecf3; --muted:#97a2b3;
    --line:#242c38; --accent:#5b8def; --accent-soft:#18233b;
    --ok:#37c07f; --warn:#e0972f; --bad:#e5645a; --grid:#1c232e; }
  :root[data-theme="light"]{ --bg:#f7f8fa; --panel:#ffffff; --ink:#1a2230; --muted:#5c6675;
    --line:#e3e7ee; --accent:#2f6df0; --accent-soft:#eaf1fe;
    --ok:#1f9d63; --warn:#c9781a; --bad:#c93838; --grid:#eef1f6; }
  *{ box-sizing:border-box; }
  body{ margin:0; background:var(--bg); color:var(--ink);
    font:15px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif; }
  header{ padding:22px 28px 10px; }
  h1{ font-size:20px; margin:0 0 2px; font-weight:640; letter-spacing:-0.01em; }
  .sub{ color:var(--muted); font-size:13px; }
  .wrap{ display:grid; grid-template-columns:320px 1fr; gap:18px; padding:14px 28px 40px; }
  @media (max-width:1024px){ .wrap{ grid-template-columns:1fr; } }
  .panel{ background:var(--panel); border:1px solid var(--line); border-radius:12px; padding:18px; }
  .panel h2{ font-size:12px; text-transform:uppercase; letter-spacing:0.06em;
    color:var(--muted); margin:0 0 14px; font-weight:650; }
  .ctrl{ margin-bottom:16px; }
  .ctrl label{ display:flex; justify-content:space-between; font-size:13px; margin-bottom:6px; }
  .ctrl label .val{ font-variant-numeric:tabular-nums; color:var(--accent); font-weight:600; }
  input[type=range]{ width:100%; accent-color:var(--accent); }
  select,input[type=number]{ width:100%; padding:7px 9px; border:1px solid var(--line);
    border-radius:8px; background:var(--bg); color:var(--ink); font-size:14px; }
  .seg{ display:flex; border:1px solid var(--line); border-radius:8px; overflow:hidden; }
  .seg button{ flex:1; border:0; background:var(--panel); color:var(--muted);
    padding:7px 4px; font-size:13px; cursor:pointer; }
  .seg button.on{ background:var(--accent); color:#fff; font-weight:600; }
  .grid-out{ display:grid; grid-template-columns:1fr 1fr; gap:18px; }
  @media (max-width:720px){ .grid-out{ grid-template-columns:1fr; } }
  .span2{ grid-column:1 / -1; }
  .hero{ display:flex; align-items:baseline; gap:14px; flex-wrap:wrap; }
  .hero .lod{ font-size:44px; font-weight:700; letter-spacing:-0.02em; font-variant-numeric:tabular-nums; }
  .pill{ padding:3px 10px; border-radius:999px; font-size:13px; font-weight:650; }
  .pill.pass{ background:color-mix(in srgb,var(--ok) 16%,transparent); color:var(--ok); }
  .pill.miss{ background:color-mix(in srgb,var(--bad) 16%,transparent); color:var(--bad); }
  .hero .note{ color:var(--muted); font-size:13px; width:100%; }
  .bars{ margin-top:6px; }
  .bar-row{ display:flex; align-items:center; gap:10px; margin:8px 0; font-size:13px; }
  .bar-row .k{ width:96px; color:var(--muted); }
  .bar-track{ flex:1; height:16px; background:var(--grid); border-radius:5px; overflow:hidden; }
  .bar-fill{ height:100%; border-radius:5px; }
  .bar-row .v{ width:96px; text-align:right; font-variant-numeric:tabular-nums; }
  .interp{ font-size:14px; line-height:1.6; }
  .lever{ font-size:14px; margin:7px 0; padding-left:16px; position:relative; }
  .lever::before{ content:"→"; position:absolute; left:0; color:var(--accent); }
  .lever.no::before{ content:"✕"; color:var(--bad); }
  .banner{ border-radius:10px; padding:12px 14px; font-size:14px; font-weight:560; margin-bottom:16px; display:none; }
  .banner.floor{ background:color-mix(in srgb,var(--bad) 14%,transparent); color:var(--bad);
    border:1px solid color-mix(in srgb,var(--bad) 35%,transparent); }
  .banner.proxy{ background:color-mix(in srgb,var(--warn) 12%,transparent); color:var(--warn);
    border:1px solid color-mix(in srgb,var(--warn) 30%,transparent); }
  .banner.drift{ background:color-mix(in srgb,var(--bad) 18%,transparent); color:var(--bad);
    border:1px solid var(--bad); }
  .plot{ width:100%; height:320px; }
  .foot{ color:var(--muted); font-size:12px; padding:0 28px 30px; }
  code{ background:var(--grid); padding:1px 5px; border-radius:4px; font-size:12px; }
</style>
</head>
<body>
<header>
  <h1>ctDNA MRD — limit-of-detection design tool</h1>
  <div class="sub">Scenario <strong>{{ name }}</strong> · live analytic model · all levels shown as
    <strong>tumour fraction (TF)</strong> unless axis-labelled VAF · numbers are order-of-magnitude priors, not measurements.</div>
</header>

<div id="drift" class="banner drift"></div>

<div class="wrap">
  <!-- CONTROLS -->
  <div class="panel">
    <h2>Assay configuration</h2>
    <div class="ctrl">
      <label>cfDNA input <span class="val"><span id="inV"></span> ng</span></label>
      <input type="range" id="input_ng" min="5" max="100" step="1">
    </div>
    <div class="ctrl">
      <label>Conversion efficiency <span class="val"><span id="convV"></span>%</span></label>
      <input type="range" id="conv" min="10" max="90" step="1">
    </div>
    <div class="ctrl">
      <label>Panel size (N, log) <span class="val"><span id="nV"></span></span></label>
      <input type="range" id="nlog" min="1" max="3.699" step="0.01">
    </div>
    <div class="ctrl">
      <label>Error regime</label>
      <div class="seg" id="regime">
        <button data-r="RAW">Raw</button>
        <button data-r="SSCS">SSCS</button>
        <button data-r="DUPLEX">Duplex</button>
        <button data-r="CUSTOM">Custom</button>
      </div>
    </div>
    <div class="ctrl" id="customWrap" style="display:none">
      <label>Custom ε (log) <span class="val">10<sup><span id="epsExpV"></span></sup></span></label>
      <input type="range" id="epslog" min="-8" max="-2" step="0.05">
    </div>
    <div class="ctrl">
      <label>Target specificity</label>
      <select id="spec">
        <option value="0.95">95%</option>
        <option value="0.99" selected>99%</option>
        <option value="0.995">99.5%</option>
        <option value="0.999">99.9%</option>
      </select>
    </div>
    <div class="ctrl">
      <label>Detection rule</label>
      <select id="rule">
        <option value="aggregate">Aggregate Poisson</option>
        <option value="kofn">k-of-N (Signatera-style)</option>
        <option value="lr">Likelihood ratio (approx)</option>
      </select>
    </div>
    <div class="ctrl">
      <label>Target LoD <span class="val">% TF</span></label>
      <input type="number" id="target" min="0" step="0.0001">
      <div class="sub" id="targetVafNote" style="margin-top:5px"></div>
    </div>
  </div>

  <!-- OUTPUTS -->
  <div class="grid-out">
    <div class="panel span2">
      <div id="proxy" class="banner proxy">Likelihood-ratio rule shown via the aggregate-Poisson
        approximation (it has no closed form; it is the most efficient rule and the aggregate sits just below it at ppm scale).</div>
      <div id="floor" class="banner floor"></div>
      <h2>Achievable limit of detection</h2>
      <div class="hero">
        <div class="lod" id="lodOut">—</div>
        <div class="pill" id="passPill">—</div>
        <div class="note" id="lodNote"></div>
      </div>
    </div>

    <div class="panel">
      <h2>Molecule budget at target</h2>
      <div class="bars">
        <div class="bar-row"><div class="k">Mutant</div>
          <div class="bar-track"><div class="bar-fill" id="mutBar" style="background:var(--accent)"></div></div>
          <div class="v" id="mutV"></div></div>
        <div class="bar-row"><div class="k">Background</div>
          <div class="bar-track"><div class="bar-fill" id="bgBar" style="background:var(--muted)"></div></div>
          <div class="v" id="bgV"></div></div>
      </div>
      <div class="sub" id="ratioV" style="margin-top:8px"></div>
    </div>

    <div class="panel">
      <h2>Effective molecules</h2>
      <div class="interp" id="budgetProse"></div>
    </div>

    <div class="panel span2">
      <h2>Detection probability vs VAF (current settings)</h2>
      <div id="curve" class="plot"></div>
    </div>

    <div class="panel span2">
      <h2>LoD surface — panel size × input mass</h2>
      <div id="surface" class="plot" style="height:380px"></div>
      <div class="sub">Analytic-valid regime: depth dispersion and site dropout are not modelled here.</div>
    </div>

    <div class="panel span2">
      <h2>Interpretation</h2>
      <div class="interp" id="interp"></div>
    </div>

    <div class="panel span2" id="wwitPanel">
      <h2>What would it take?</h2>
      <div id="wwit"></div>
    </div>
  </div>
</div>

<div class="foot">
  Generated by <code>mrd-lod-sim</code>. The JS model reimplements the Python analytic path
  (BUILD_SPEC 4.2) and is checked on load against reference vectors from the package.
  Simulation is permanently necessary: real samples cannot provide ground truth at ppm.
</div>

<script>
const PAYLOAD = {{ payload_json | safe }};

// ---- analytic model (mirror of analytic.py) ----------------------------
const M = {
  lgamma(x){
    const c=[0.99999999999980993,676.5203681218851,-1259.1392167224028,
      771.32342877765313,-176.61502916214059,12.507343278686905,
      -0.13857109526572012,9.9843695780195716e-6,1.5056327351493116e-7];
    if(x<0.5) return Math.log(Math.PI/Math.sin(Math.PI*x))-this.lgamma(1-x);
    x-=1; let a=c[0]; const g=7, t=x+g+0.5;
    for(let i=1;i<9;i++) a+=c[i]/(x+i);
    return 0.5*Math.log(2*Math.PI)+(x+0.5)*Math.log(t)-t+Math.log(a);
  },
  erf(x){ const s=x<0?-1:1; x=Math.abs(x);
    const t=1/(1+0.3275911*x);
    const y=1-(((((1.061405429*t-1.453152027)*t)+1.421413741)*t-0.284496736)*t+0.254829592)*t*Math.exp(-x*x);
    return s*y; },
  normCdf(z){ return 0.5*(1+this.erf(z/Math.SQRT2)); },
  poissonLogPmf(k,lam){ return k*Math.log(lam)-lam-this.lgamma(k+1); },
  poissonCdf(k,lam){ // P(X<=k)
    k=Math.floor(k);
    if(lam<=0) return 1.0;
    if(k<0) return 0.0;
    if(lam>1000) return this.normCdf((k+0.5-lam)/Math.sqrt(lam));
    let s=0; for(let i=0;i<=k;i++) s+=Math.exp(this.poissonLogPmf(i,lam));
    return Math.min(1,s);
  },
  poissonSfGe(t,lam){ return 1-this.poissonCdf(t-1,lam); }, // P(X>=t)
  countThreshold(lamBg,alpha){
    let t=1; const cap=Math.ceil(lamBg*10+2000);
    while(this.poissonSfGe(t,lamBg)>alpha && t<cap) t++;
    return t;
  },
  binomSfGe(k,n,p){ // P(K>=k)
    if(k<=0) return 1; if(p<=0) return 0; if(p>=1) return 1;
    if(n*p>1000) return 1-this.normCdf((k-0.5-n*p)/Math.sqrt(n*p*(1-p)));
    const lp=Math.log(p), lq=Math.log1p(-p), lgn=this.lgamma(n+1);
    let s=0;
    for(let i=Math.ceil(k);i<=n;i++){
      s+=Math.exp(lgn-this.lgamma(i+1)-this.lgamma(n-i+1)+i*lp+(n-i)*lq);
      if(i>n*p && this.lgamma(n+1)!==Infinity && Math.exp(lgn-this.lgamma(i+1)-this.lgamma(n-i+1)+i*lp+(n-i)*lq)<1e-15 && i>n*p+10) break;
    }
    return Math.min(1,s);
  },
  geEff(s){ return s.input_ng/s.pg * s.conv * s.strand; },
  aggregate(s,vaf){
    const ge=this.geEff(s), lamBg=ge*s.n*s.eps, lamSig=ge*s.n*vaf*s.e_ccf;
    const t=this.countThreshold(lamBg,s.alpha);
    return this.poissonSfGe(t,lamBg+lamSig);
  },
  kofn(s,vaf){
    const ge=this.geEff(s), lamB=ge*s.eps, lamS=ge*vaf*s.e_ccf;
    const t=this.countThreshold(lamB,s.per_site_alpha);
    const pSite=this.poissonSfGe(t,lamB+lamS);
    return this.binomSfGe(s.k,s.n,pSite);
  },
  detect(s,vaf){ return s.rule==='kofn' ? this.kofn(s,vaf) : this.aggregate(s,vaf); },
  achievableLod(s,hit){
    let lo=1e-9, hi=0.5;
    if(this.detect(s,hi)<hit) return Infinity;
    if(this.detect(s,lo)>=hit) return lo;
    for(let i=0;i<80;i++){ const mid=Math.sqrt(lo*hi);
      if(this.detect(s,mid)>=hit) hi=mid; else lo=mid; }
    return hi;
  }
};

// ---- golden-vector self-check (Python/JS drift guard, BUILD_SPEC 8.1) ---
(function(){
  let maxErr=0;
  for(const r of PAYLOAD.golden){
    const s={input_ng:r.input_ng,conv:r.conv,strand:r.strand,pg:r.pg,n:r.n,
      e_ccf:r.e_ccf,eps:r.eps,alpha:r.alpha,rule:'aggregate'};
    maxErr=Math.max(maxErr,Math.abs(M.aggregate(s,r.vaf)-r.p));
  }
  if(maxErr>1e-6){
    const b=document.getElementById('drift');
    b.style.display='block';
    b.textContent='⚠ JS analytic model diverges from the Python reference (max error '
      +maxErr.toExponential(2)+'). Do not trust these numbers.';
  } else { console.log('golden-vector check OK, max error '+maxErr.toExponential(2)); }
})();

// ---- state & helpers ---------------------------------------------------
const cur=PAYLOAD.current, tgt=PAYLOAD.target;
const $=id=>document.getElementById(id);
let state={
  input_ng:cur.input_ng, conv:cur.conversion_efficiency, strand:cur.strand_recovery,
  pg:cur.pg_per_ge, n:cur.n_variants, e_ccf:cur.e_ccf, eps:cur.eps,
  regime:regimeOf(cur.eps), spec:tgt.specificity, rule:PAYLOAD.meta.rule,
  k:cur.k, per_site_alpha:cur.per_site_alpha, targetTF:tgt.tf
};
function regimeOf(eps){
  for(const [k,v] of Object.entries(PAYLOAD.regimes)) if(Math.abs(eps-v)/v<0.01) return k;
  return 'CUSTOM';
}
function ruleKey(name){ return name==='KofNRule'?'kofn':name==='LikelihoodRatioRule'?'lr':'aggregate'; }
state.rule=ruleKey(PAYLOAD.meta.rule);

const fmtPct=v=>{ // fraction -> "x ppm TF" or "%" sensibly
  const ppm=v*1e6;
  if(ppm<1) return (ppm*1000).toPrecision(2)+' ppb TF';
  if(ppm<1000) return ppm.toPrecision(3)+' ppm TF';
  return (v*100).toPrecision(3)+'% TF';
};
const fmtNum=v=> v>=100?Math.round(v).toLocaleString(): v>=1?v.toPrecision(3): v.toExponential(2);

// settings object for the model (VAF space). alpha = 1 - specificity.
function modelSettings(){
  return {input_ng:state.input_ng,conv:state.conv,strand:state.strand,pg:state.pg,
    n:state.n,e_ccf:state.e_ccf,eps:state.eps,alpha:1-state.spec,rule:state.rule,
    k:state.k,per_site_alpha:state.per_site_alpha};
}
const tfToVaf=tf=>tf/2, vafToTf=v=>v*2;

// ---- render ------------------------------------------------------------
function render(){
  const s=modelSettings();
  const hit=tgt.hit_rate;
  const lodVaf=M.achievableLod(s,hit);
  const lodTF=vafToTf(lodVaf);
  const targetVaf=tfToVaf(state.targetTF);

  // hero
  $('lodOut').textContent = isFinite(lodVaf)? fmtPct(lodTF) : 'unreachable';
  const pass = isFinite(lodVaf) && lodTF<=state.targetTF*1.0001;
  const pill=$('passPill');
  pill.textContent = pass? 'MEETS TARGET':'MISSES TARGET';
  pill.className='pill '+(pass?'pass':'miss');
  $('lodNote').textContent =
    `at ${(hit*100).toFixed(0)}% detection and ${(state.spec*100).toFixed(1)}% specificity · `+
    `target ${fmtPct(state.targetTF)} · LoD shown as TF (VAF = TF/2)`;

  // molecule budget at target
  const ge=M.geEff(s);
  const mut=ge*s.n*targetVaf*s.e_ccf, bg=ge*s.n*s.eps;
  const mx=Math.max(mut,bg,1e-9);
  $('mutBar').style.width=(100*mut/mx)+'%';
  $('bgBar').style.width=(100*bg/mx)+'%';
  $('mutV').textContent=fmtNum(mut)+' mol';
  $('bgV').textContent=fmtNum(bg)+' mol';
  $('ratioV').textContent=`signal:background ≈ ${(mut/Math.max(bg,1e-9)).toPrecision(2)} : 1  ·  `+
    `${fmtNum(ge)} effective GE interrogated`;

  // poisson floor
  const floor=$('floor');
  if(mut<3){ floor.style.display='block';
    floor.textContent=`Below the sampling floor — expected mutant molecules ≈ ${mut.toPrecision(2)} (<3). `+
      `The molecules are not present in the sample; no additional sequencing depth can recover this.`;
  } else floor.style.display='none';

  // proxy banner
  $('proxy').style.display = state.rule==='lr' ? 'block':'none';

  // budget prose
  $('budgetProse').innerHTML =
    `At <b>${fmtNum(state.input_ng)} ng</b> input with <b>${Math.round(state.conv*100)}%</b> conversion you `+
    `interrogate <b>${fmtNum(ge)}</b> effective genome equivalents. Across <b>${fmtNum(state.n)}</b> tracked `+
    `variants at ${fmtPct(state.targetTF)} you expect <b>${fmtNum(mut)}</b> mutant vs <b>${fmtNum(bg)}</b> `+
    `background molecules.`;

  drawCurve(s,lodVaf,hit);
  drawSurface(s,hit);
  drawInterp(s,lodTF,pass,mut,bg);
  drawWwit(s,targetVaf,hit,pass);
}

function drawCurve(s,lodVaf,hit){
  const xs=[], ys=[];
  const centre = isFinite(lodVaf)? lodVaf : tfToVaf(state.targetTF);
  const lo=Math.log10(centre/60), hi=Math.log10(centre*60);
  for(let i=0;i<=60;i++){ const v=Math.pow(10,lo+(hi-lo)*i/60); xs.push(v); ys.push(M.detect(s,v)); }
  const mc=PAYLOAD.mc_curve;
  const traces=[
    {x:xs,y:ys,mode:'lines',name:'analytic',line:{color:'#2f6df0',width:2.5}},
    {x:mc.map(d=>d.vaf),y:mc.map(d=>d.p),mode:'markers',name:'Monte Carlo',
      marker:{color:'#c9781a',size:6,symbol:'circle-open'}}
  ];
  if(isFinite(lodVaf)) traces.push({x:[lodVaf],y:[hit],mode:'markers',name:'LoD',
    marker:{color:'#1f9d63',size:11,symbol:'x'}});
  Plotly.react('curve',traces,{
    margin:{l:52,r:12,t:8,b:44}, paper_bgcolor:'transparent', plot_bgcolor:'transparent',
    font:{color:getCss('--ink')}, showlegend:true, legend:{orientation:'h',y:1.12},
    xaxis:{type:'log',title:'per-site VAF',gridcolor:getCss('--grid')},
    yaxis:{title:'P(detect)',range:[0,1.02],gridcolor:getCss('--grid')},
    shapes:[{type:'line',x0:xs[0],x1:xs[xs.length-1],y0:hit,y1:hit,
      line:{color:getCss('--muted'),dash:'dot',width:1}}]
  },{displayModeBar:false,responsive:true});
}

function drawSurface(s,hit){
  const NS=[], MS=[], Z=[];
  const nGrid=[], mGrid=[];
  for(let i=0;i<16;i++) nGrid.push(Math.round(Math.pow(10,1+(3.699-1)*i/15)));
  for(let j=0;j<16;j++) mGrid.push(5+(100-5)*j/15);
  for(const m of mGrid){ const row=[];
    for(const n of nGrid){ const ss=Object.assign({},s,{input_ng:m,n:n});
      const lod=M.achievableLod(ss,hit);
      row.push(isFinite(lod)? Math.log10(vafToTf(lod)) : null); }
    Z.push(row); }
  Plotly.react('surface',[{
    z:Z,x:nGrid,y:mGrid,type:'contour',colorscale:'Viridis',
    colorbar:{title:'log₁₀ TF LoD',titleside:'right'},
    contours:{coloring:'heatmap'}
  },{
    x:[state.n],y:[state.input_ng],mode:'markers',type:'scatter',
    marker:{color:'#fff',size:12,symbol:'cross-thin',line:{color:'#000',width:2}},
    name:'current'
  },{
    z:Z,x:nGrid,y:mGrid,type:'contour',showscale:false,
    contours:{start:Math.log10(state.targetTF),end:Math.log10(state.targetTF),
      coloring:'lines'}, line:{color:'#c93838',width:2.5}
  }],{
    margin:{l:56,r:12,t:8,b:46}, paper_bgcolor:'transparent', plot_bgcolor:'transparent',
    font:{color:getCss('--ink')}, showlegend:false,
    xaxis:{type:'log',title:'panel size (N)'}, yaxis:{title:'cfDNA input (ng)'}
  },{displayModeBar:false,responsive:true});
}

function drawInterp(s,lodTF,pass,mut,bg){
  let msg=`This configuration achieves an LoD of <b>${fmtPct(lodTF)}</b>. `;
  if(pass) msg+=`That <b>meets</b> the ${fmtPct(state.targetTF)} target. `;
  else msg+=`That <b>misses</b> the ${fmtPct(state.targetTF)} target. `;
  if(mut<3) msg+=`Expected mutant molecules (${mut.toPrecision(2)}) are below the sampling floor — the limit is the sample, not the sequencer. `;
  else if(bg>mut) msg+=`Background (${fmtNum(bg)} mol) exceeds signal (${fmtNum(mut)} mol) at target; a lower-error regime would help most. `;
  else msg+=`Signal comfortably exceeds background at target. `;
  if(state.rule==='lr') msg+=`(LR shown via the aggregate-Poisson approximation.)`;
  $('interp').innerHTML=msg;
}

function drawWwit(s,targetVaf,hit,pass){
  const panel=$('wwitPanel');
  if(pass){ panel.style.display='none'; return; }
  panel.style.display='block';
  const out=[];
  // one lever at a time (mirror of surface.what_would_it_take)
  out.push(lever('Panel size', s,'n', state.n, 100000, 5000, v=>Math.ceil(v)+' variants', targetVaf,hit,true));
  out.push(lever('cfDNA input', s,'input_ng', state.input_ng, 1000, 100, v=>Math.round(v)+' ng', targetVaf,hit,true));
  out.push(lever('Conversion', s,'conv', state.conv, 0.9, 0.9, v=>Math.round(v*100)+'%', targetVaf,hit,true));
  out.push(leverEps(s,targetVaf,hit));
  $('wwit').innerHTML=`<div class="sub" style="margin-bottom:8px">Minimum change in each single lever (others held fixed):</div>`+out.join('');
}
function lever(name,s,key,cur0,max,plaus,fmt,targetVaf,hit,incr){
  const meets=x=>{const ss=Object.assign({},s);ss[key]=key==='n'?Math.ceil(x):x;return M.detect(ss,targetVaf)>=hit;};
  if(meets(cur0)) return `<div class="lever">${name}: already sufficient</div>`;
  if(!meets(max)) return `<div class="lever no">${name}: cannot reach the target alone</div>`;
  let lo=cur0,hi=max; for(let i=0;i<80;i++){const mid=(lo+hi)/2; if(meets(mid))hi=mid;else lo=mid;}
  const ok=hi<=plaus;
  return `<div class="lever${ok?'':' no'}">${name}: ${fmt(hi)}${ok?'':' (beyond a plausible range)'}</div>`;
}
function leverEps(s,targetVaf,hit){
  const meets=e=>M.detect(Object.assign({},s,{eps:e}),targetVaf)>=hit;
  if(meets(s.eps)) return `<div class="lever">Error regime: already sufficient</div>`;
  if(!meets(1e-9)) return `<div class="lever no">Error regime: cannot reach the target alone</div>`;
  let lo=1e-9,hi=s.eps; for(let i=0;i<80;i++){const mid=Math.sqrt(lo*hi); if(meets(mid))lo=mid;else hi=mid;}
  let named=null;
  for(const [k,v] of Object.entries(PAYLOAD.regimes).sort((a,b)=>b[1]-a[1])) if(v<=lo){named=k;break;}
  return `<div class="lever${named?'':' no'}">Error regime: reduce ε to ≤ ${lo.toExponential(1)}`+
    (named?` (the ${named} regime reaches this)`:` (below any named regime)`)+`</div>`;
}

function getCss(v){ return getComputedStyle(document.documentElement).getPropertyValue(v).trim(); }

// ---- wire controls -----------------------------------------------------
function setRegimeButtons(){
  document.querySelectorAll('#regime button').forEach(b=>
    b.classList.toggle('on', b.dataset.r===state.regime));
  $('customWrap').style.display = state.regime==='CUSTOM'?'block':'none';
}
function syncInputs(){
  $('input_ng').value=state.input_ng; $('inV').textContent=state.input_ng;
  $('conv').value=state.conv*100; $('convV').textContent=Math.round(state.conv*100);
  $('nlog').value=Math.log10(state.n); $('nV').textContent=fmtNum(state.n);
  $('spec').value=state.spec; $('rule').value=state.rule;
  $('target').value=+(state.targetTF*100).toPrecision(4);
  $('targetVafNote').textContent=`= ${fmtPct(state.targetTF)}  ·  VAF = ${fmtPct(tfToVaf(state.targetTF)).replace(' TF','')} `;
  $('epslog').value=Math.log10(state.eps); $('epsExpV').textContent=Math.log10(state.eps).toFixed(1);
  setRegimeButtons();
}
let raf=null; function schedule(){ if(raf) cancelAnimationFrame(raf); raf=requestAnimationFrame(render); }

$('input_ng').oninput=e=>{state.input_ng=+e.target.value;$('inV').textContent=state.input_ng;schedule();};
$('conv').oninput=e=>{state.conv=+e.target.value/100;$('convV').textContent=e.target.value;schedule();};
$('nlog').oninput=e=>{state.n=Math.round(Math.pow(10,+e.target.value));$('nV').textContent=fmtNum(state.n);schedule();};
$('spec').onchange=e=>{state.spec=+e.target.value;schedule();};
$('rule').onchange=e=>{state.rule=e.target.value;schedule();};
$('target').oninput=e=>{state.targetTF=Math.max(0,+e.target.value/100);
  $('targetVafNote').textContent=`= ${fmtPct(state.targetTF)}  ·  VAF = ${fmtPct(tfToVaf(state.targetTF)).replace(' TF','')} `;schedule();};
$('epslog').oninput=e=>{state.eps=Math.pow(10,+e.target.value);$('epsExpV').textContent=(+e.target.value).toFixed(1);schedule();};
document.querySelectorAll('#regime button').forEach(b=>b.onclick=()=>{
  state.regime=b.dataset.r;
  if(state.regime!=='CUSTOM') state.eps=PAYLOAD.regimes[state.regime];
  setRegimeButtons(); syncInputs(); schedule();
});

syncInputs(); render();
</script>
</body>
</html>
